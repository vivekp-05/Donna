LLM_PROVIDER=mock            # mock | anthropic | insforge | gemini
ANTHROPIC_API_KEY=
INSFORGE_AI_BASE_URL=        # e.g. https://<project>.insforge.app/api/ai/v1
INSFORGE_AI_KEY=
INSFORGE_AI_MODEL=anthropic/claude-sonnet-4.5
GEMINI_API_KEY=             # for LLM_PROVIDER=gemini (Google AI Studio key)
GEMINI_MODEL=gemini-2.5-flash
DB_PROVIDER=json             # json | insforge
INSFORGE_BASE_URL=
INSFORGE_API_KEY=
VOICE_PROVIDER=sim           # sim | vapi
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# Safety valve: redirect EVERY live outbound call to this E.164 number, whichever
# recipient the scoring engine picks. Scoring/ranking are unaffected — only the
# dial target. Always set this when demoing against the seeded fake numbers.
LIVE_CALL_PHONE_OVERRIDE=
# Public origin VAPI posts call reports back to (no path — /api/vapi/webhook is
# appended). An ngrok tunnel in dev; the deployed InsForge function on stage.
# REQUIRED for live calls: unset, VAPI has nowhere to report, so every call times
# out after 90s and records no_answer regardless of what was said.
PUBLIC_WEBHOOK_URL=
# Shared secret VAPI echoes back in the X-Vapi-Secret header. Set it whenever the
# webhook is publicly reachable — an open tunnel lets anyone forge an "accepted".
VAPI_WEBHOOK_SECRET=
PORT=8787
# The organisation Donna says she works for, on every inbound and outbound call.
# Must be an org you actually run — the assistant states it as fact to donors and
# pantries. Unset degrades to the generic "the food bank" (honest); never set it
# to a real food bank you are not.
FOOD_BANK_NAME=
